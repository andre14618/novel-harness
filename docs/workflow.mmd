flowchart TD
    Start([bun src/index.ts]) --> InputCheck{--resume?}
    InputCheck -->|Yes| Resume[Load novel from DB]
    InputCheck -->|No| AutoCheck{--auto?}
    AutoCheck -->|Yes| TestSeed[Use TEST_SEED]
    AutoCheck -->|No| Collect[collectSeedInput via CLI]
    TestSeed --> InitDB[initDB + createNovel]
    Collect --> InitDB
    Resume --> PhaseLoop
    InitDB --> PhaseLoop

    subgraph PhaseLoop["State Machine Loop"]
        direction TB
        CheckPhase{novel.phase?}

        subgraph Concept["Phase 1: Concept"]
            direction TB
            WB["🌍 World Builder Agent\nSeed → WorldBible schema\ntemp 0.7"]
            WB --> WBGate{Approve?}
            WBGate -->|Reject| WBRetry["Retry temp 0.8"] --> WBSave
            WBGate -->|Approve| WBSave[saveWorldBible]

            WBSave --> CA["👤 Character Agent\nSeed + World → CharacterProfiles schema\ntemp 0.7"]
            CA --> CAGate{Approve?}
            CAGate -->|Reject| CARetry["Retry temp 0.8"] --> CASave
            CAGate -->|Approve| CASave[saveCharacter × N]

            CASave --> PA["📐 Plotter Agent\nSeed + World + Chars → StorySpine schema\ntemp 0.7"]
            PA --> PAGate{Approve?}
            PAGate -->|Reject| PARetry["Retry temp 0.8"] --> PASave
            PAGate -->|Approve| PASave[saveStorySpine]
        end

        subgraph Planning["Phase 2: Planning"]
            direction TB
            Ctx2["buildPlanningContext\nWorld + Chars + Spine + Seed"]
            Ctx2 --> PP["📋 Planning Plotter Agent\nContext → 3 ChapterOutlines\ntemp 0.6"]
            PP --> PPGate{Approve?}
            PPGate -->|Reject| PPRetry["Retry temp 0.7"] --> PPSave
            PPGate -->|Approve| PPSave["saveChapterOutline × 3\nupdateTotalChapters"]
        end

        subgraph Drafting["Phase 3: Drafting — per chapter (1-3)"]
            direction TB
            CtxW["buildWriterContext\nOutline + Chars + World + Summaries\n+ CharStates + OpenIssues"]
            CtxW --> Writer["✍️ Writer Agent\nContext → ChapterDraft.prose\ntemp 0.8"]
            Writer --> Validate["validateChapterDraft\n• Word count checks\n• POV character present\n• Listed characters mentioned"]
            Validate --> ValResult{Blockers?}
            ValResult -->|Yes| RetryWrite["Retry (max 3 attempts)"]
            RetryWrite --> CtxW
            ValResult -->|No| Continuity["🔍 Continuity Agent\nDraft + Facts + CharStates\ntemp 0.2"]
            Continuity --> SaveDraft[saveChapterDraft]
            SaveDraft --> HumanGate{Approve?}

            HumanGate -->|Reject| RetryWrite
            HumanGate -->|Revise| RevNotes["Record revision notes\nas blocker issues"] --> RetryWrite

            HumanGate -->|Approve| StateExtract

            subgraph StateExtract["State Extraction (sequential)"]
                direction LR
                SE["📝 Summary Extractor\ntemp 0.2"]
                FE["🔎 Fact Extractor\ntemp 0.1"]
                CS["📍 Character State\ntemp 0.1"]
                SE --> FE --> CS
            end

            StateExtract --> Checkpoint["Checkpoint\n• saveChapterSummary\n• saveFact × N\n• saveCharacterState × N\n• resolveIssues\n• write chapter-N.md\n• updateCurrentChapter"]
            Checkpoint --> NextCh{More chapters?}
            NextCh -->|Yes| CtxW
        end

        CheckPhase -->|concept| Concept
        Concept --> SetPlanning["updatePhase → planning"]
        SetPlanning --> CheckPhase

        CheckPhase -->|planning| Planning
        Planning --> SetDrafting["updatePhase → drafting"]
        SetDrafting --> CheckPhase

        subgraph Validation["Phase 4: Validation — multi-pass"]
            direction TB
            VStart["For each pass (max 3)"]
            VStart --> DetCheck["Deterministic checks\n• Word count, POV, chars\n• Scene beat coverage\n• Dialogue ratio\n• POV pronoun check"]
            DetCheck --> DetResult{Blockers?}
            DetResult -->|Yes| FileIssues["saveIssue per blocker"]
            DetResult -->|No| CrossChapter["🔍 Cross-Chapter Continuity\nAll summaries + facts\ntemp 0.2"]
            CrossChapter --> CCResult{Issues?}
            CCResult -->|No| Converged["Converged!"]
            CCResult -->|Yes| FileIssues
            FileIssues --> StuckCheck{Attempts > 3?}
            StuckCheck -->|Yes| Stuck["Mark stuck, skip"]
            StuckCheck -->|No| Rewrite["✍️ Rewriter Agent\nDraft + issues + facts\ntemp 0.5"]
            Rewrite --> RewriteVal{Rewrite valid?}
            RewriteVal -->|No| Stuck
            RewriteVal -->|Yes| RewriteSave["unapprove old draft\nsave + approve new\nclear + re-extract state"]
            RewriteSave --> VStart
            Stuck --> VStart
        end

        CheckPhase -->|drafting| Drafting
        NextCh -->|No| SetValidation["updatePhase → validation"]
        SetValidation --> CheckPhase

        CheckPhase -->|validation| Validation
        Converged --> SetDone["updatePhase → done"]
        SetDone --> CheckPhase

        CheckPhase -->|done| Done
    end

    Done([Novel Complete\noutput/novelId/chapter-1..3.md])

    style Concept fill:#1a3a2a,stroke:#4ade80,color:#e0e0e0
    style Planning fill:#1a2a3a,stroke:#60a5fa,color:#e0e0e0
    style Drafting fill:#3a2a1a,stroke:#f59e0b,color:#e0e0e0
    style Validation fill:#2a1a1a,stroke:#f87171,color:#e0e0e0
    style StateExtract fill:#2a1a2a,stroke:#c084fc,color:#e0e0e0
    style Done fill:#1a3a1a,stroke:#4ade80,color:#e0e0e0
    style Start fill:#1a1a2a,stroke:#818cf8,color:#e0e0e0
