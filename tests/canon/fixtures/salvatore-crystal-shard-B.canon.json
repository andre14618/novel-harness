{
  "novelId": "salvatore-crystal-shard",
  "snapshotVersion": "salvatore-poc-v1-subagent-B",
  "description": "Manual canon for R.A. Salvatore's The Crystal Shard, chapters 4-5 (subagent B; merges with subagent A's prelude+ch1-3 output)",
  "facts": [
    {
      "id": "fact-kessell-abandoned-in-spine-of-the-world",
      "kind": "established_fact",
      "text": "Eldulac, Dendybar the Mottled, and the other Hosttower wizards abandoned Akar Kessell in a snow-filled bowl in the Spine of the World, intending him to die after he served his purpose by murdering Morkai the Red.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kessell-realizes-betrayal",
      "kind": "knowledge_change",
      "text": "Akar Kessell realizes the Hosttower wizards never intended to grant him the title of wizard and used him only as a pawn to rid themselves of Morkai the Red.",
      "data": { "characterId": "akar-kessell" },
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "observed",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-crenshinibon-is-ancient-sentient-relic",
      "kind": "established_fact",
      "text": "Crenshinibon, the Crystal Shard, is an ancient sentient relic enchanted at the dawn of the world; a force of darkest evil that draws strength from the light of day, and a perversion lost for centuries that evil lords have long sought.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-crenshinibon-powers",
      "kind": "established_fact",
      "text": "Crenshinibon serves as an instrument of destruction, a tool for scrying, and a shelter and home for its wielder; foremost it imparts great magical strength to its possessor.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kessell-finds-crenshinibon",
      "kind": "knowledge_change",
      "text": "Dying in the snow, Akar Kessell digs up a warm crystal shard buried beneath the bowl's center; it revives him and he claims it without understanding what it is.",
      "data": { "characterId": "akar-kessell" },
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "observed",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-crenshinibon-manipulates-kessell-via-dreams",
      "kind": "established_fact",
      "text": "Crenshinibon imposes dreams on its sleeping host and uses nighttime suggestions to slowly mold a weak-willed wielder toward conquest; it intends to nurture Kessell into a proper representative of its destructive power.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kessell-gains-magical-power",
      "kind": "knowledge_change",
      "text": "Possessing Crenshinibon, Kessell gains spellcasting power far beyond what Morkai ever taught him, including a lightning-bolt kill on a deer and telekinesis to retrieve it.",
      "data": { "characterId": "akar-kessell" },
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "observed",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-cryshal-tirith-creation",
      "kind": "established_fact",
      "text": "By placing a duplicate of Crenshinibon in the snow and speaking the arcane words 'Ibssum dal abdur,' Kessell raises a mammoth crystalline tower named Cryshal-Tirith — an exact magnified image of the shard — that draws the light of the surrounding day into itself.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-cryshal-tirith-entrance-invisible",
      "kind": "established_fact",
      "text": "The entrance to Cryshal-Tirith is invisible to all except denizens of foreign planes and those whom Crenshinibon (or its wielder) allows to enter.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kessell-enslaves-goblin-tribe",
      "kind": "established_fact",
      "text": "Using a scrying mirror in Cryshal-Tirith, Kessell projects his will onto a nearby nomadic goblin tribe and compels their chieftain to enter the tower and kneel, naming Kessell 'Master' — the first followers of his nascent kingdom.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-spine-of-the-world-is-impassable",
      "kind": "established_fact",
      "text": "The Spine of the World is a foreboding range of impassable mountains; its caves are contested fiercely by orcs, goblins, ogres, and stronger monsters, and weaker goblin tribes are often driven above ground, enslaved, or slaughtered.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-bruenor-from-mithril-hall",
      "kind": "established_fact",
      "text": "Bruenor Battlehammer is the eldest surviving member of his small dwarven clan and the only one among them who personally witnessed Mithril Hall — his ancestral home — before his people were driven out by dark things from the deep.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-mithril-hall-lost-homeland",
      "kind": "established_fact",
      "text": "Mithril Hall is the lost ancestral home of Bruenor's clan, a place where rivers of mithril ran rich and dwarven smiths' hammers rang out in praise to Moradin and Dumathoin; its location is unknown and Bruenor remembers only disjointed images.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-dwarven-valley-trade",
      "kind": "established_fact",
      "text": "The dwarves' rocky valley sits between the two northernmost lakes just north of Bryn Shander; trade in dwarven armor and weapons with the warring humans of Ten-Towns has reversed the dwarves' decline, though Bruenor regards the arrangement as temporary.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kelvins-cairn-only-mountain",
      "kind": "established_fact",
      "text": "Kelvin's Cairn — named for resembling a piled grave-mound from barbarian legend — and the dwarves' rocky valley are the only features in all of Icewind Dale with mentionable quantities of rock; the surrounding tundra is otherwise flat and earthen.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-drizzt-distrusted-in-ten-towns",
      "kind": "established_fact",
      "text": "Drizzt Do'Urden is not trusted or openly welcomed in any town of Ten-Towns except Lonelywood, where Regis is spokesman; only Regis and the dwarves consider the drow a friend.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-catti-brie-orphaned-and-adopted",
      "kind": "established_fact",
      "text": "Catti-brie is a human girl orphaned years earlier in a raid on Termalaine; Bruenor took her in and raised her as his own child, and she still lives with him.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-regis-ruby-pendant-magical",
      "kind": "established_fact",
      "text": "Regis carries a finely-cut ruby pendant whose subtle magic can sway listeners; Drizzt recognizes it from legend, and Regis claims it as one of twelve similar stones his former master possessed — implying Regis stole it.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-barbarian-invasion-coming",
      "kind": "knowledge_change",
      "text": "Drizzt has confirmed that a barbarian horde is preparing to charge Ten-Towns and tells Bruenor that without unified defense the people are doomed.",
      "data": { "characterId": "drizzt" },
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "observed",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-ten-towns-council-in-bryn-shander",
      "kind": "established_fact",
      "text": "A council of Ten-Towns spokesmen meets in Bryn Shander in two days; Drizzt plans to instruct Regis to carry word of the invasion there and use the ruby's influence to forge a defensive alliance.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-kemp-of-targos-political-key",
      "kind": "established_fact",
      "text": "Kemp of Targos believes his walled city can stand alone, refuses to join any pact that includes rival Termalaine, and his cooperation is the political key without which Caer-Konig and Caer-Dineval will not commit; Easthaven and Lonelywood are reliably for unity.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-knucklehead-trout-deeper",
      "kind": "established_fact",
      "text": "Knucklehead trout have moved into the deeper waters of the lakes in recent years, making them harder to catch and driving cooperation among Ten-Towns to a low point as each town tries to gain economic advantage over rival towns on its lake.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-promise-akar-kessell-rise-payoff-begins",
      "kind": "payoff",
      "text": "The earlier setup of Kessell as the wizards' pawn pays off in his transformation: armed with Crenshinibon and Cryshal-Tirith and his first goblin servant, Akar Kessell begins his rise as the Tyrant of Icewind Dale.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-promise-cryshal-tirith-as-base-of-power",
      "kind": "promise",
      "text": "Cryshal-Tirith stands in a remote bowl of the Spine of the World as Kessell's growing seat of power; Crenshinibon intends to mold him slowly into an instrument of conquest, foreshadowing future campaigns against Ten-Towns and beyond.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 4,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-promise-mithril-hall-quest",
      "kind": "promise",
      "text": "Bruenor's deepest desire is to recover and restore Mithril Hall, and he has badgered Drizzt for years to accompany him on the quest; Drizzt humors him with 'someday' but neither knows the way.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    },
    {
      "id": "fact-promise-warn-ten-towns-council",
      "kind": "promise",
      "text": "Drizzt commits to instructing Regis on how to carry the warning of the barbarian invasion to the Ten-Towns council in Bryn Shander, using the ruby pendant to win the spokesmen — Targos and Kemp being the political key.",
      "data": {},
      "provenance": {
        "source": "post-draft-extraction",
        "chapter": 5,
        "extractorVersion": "salvatore-poc-v1",
        "approvalStatus": "human-approved",
        "origin": "planned",
        "createdAt": "2026-05-03T00:00:00Z",
        "updatedAt": "2026-05-03T00:00:00Z"
      }
    }
  ],
